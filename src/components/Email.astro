---
interface Props {
  user: string;
  domain: string;
}
const { user, domain } = Astro.props;
---
<button
  type="button"
  class="window window--focusable tile email"
  data-user={user}
  data-domain={domain}
>
  <svg viewBox="0 0 24 24" width="28" height="28" aria-hidden="true">
    <path fill="currentColor" d="M2 4h20a2 2 0 0 1 2 2v12a2 2 0 0 1-2 2H2a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2Zm10 9.5L2.5 6.7v.05L12 13.5l9.5-6.75V6.7L12 13.5Z"/>
  </svg>
  <div>
    <span class="label">Email</span>
    <span class="value" data-email-text>(Email anzeigen)</span>
    <span class="sr-only">— in Mail-Client öffnen</span>
  </div>
</button>

<style>
  .tile {
    display: flex; align-items: center; gap: 0.85rem;
    padding: 1rem 1.15rem;
    text-decoration: none; color: inherit;
    border: 0;
    cursor: pointer; text-align: left;
    font: inherit;
    width: 100%;
    min-width: 0;
  }
  /* Ohne min-width:0 greift das text-overflow: ellipsis der .value nie */
  .tile > div { min-width: 0; }
  .tile svg { flex-shrink: 0; color: var(--teal); }
  .label {
    display: block; font-size: 0.72rem;
    text-transform: lowercase;
    color: var(--overlay2);
  }
  .value {
    display: block; color: var(--text); font-size: 0.88rem;
    overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
  }
</style>

<script>
  document.querySelectorAll<HTMLButtonElement>('.tile.email').forEach((btn) => {
    const user = btn.dataset.user;
    const domain = btn.dataset.domain;
    if (!user || !domain) return;
    const email = `${user}@${domain}`;
    const span = btn.querySelector<HTMLElement>('[data-email-text]');
    if (span) span.textContent = email;
    btn.addEventListener('click', () => {
      window.location.href = `mailto:${email}`;
    });
  });
</script>
