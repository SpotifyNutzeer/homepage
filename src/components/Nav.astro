---
// Die Bar wie in Bar.qml (zen): volle Breite, opakes Mantle, 44px, keine
// Borders, keine Separatoren. Sections sind nummerierte Workspaces —
// der aktive bekommt Teal auf Crust (wsActiveBg/wsActiveFg), die Uhr
// rechts ist Sky (clockColor). Auf schmalen Screens bleiben nur die
// Workspace-Nummern übrig.
const links = [
  { href: '#about',     label: 'über mich' },
  { href: '#projects',  label: 'projekte' },
  { href: '#tools',     label: 'tools' },
  { href: '#hardware',  label: 'hardware' },
  { href: '#sidefacts', label: 'sidefacts' },
  { href: '#contact',   label: 'kontakt' }
];
---
<nav id="top-nav" aria-label="Hauptnavigation">
  <a class="brand" href="#top">paul.wtf</a>
  <ul>
    {links.map(({ href, label }, i) => (
      <li>
        <a href={href} data-section={href.slice(1)}>
          <span class="num" aria-hidden="true">{i + 1}</span>
          <span class="label">{label}</span>
        </a>
      </li>
    ))}
  </ul>
  <span class="clock" data-clock aria-hidden="true">--:--</span>
</nav>

<style is:global>
  /* Die Bar ersetzt die obere Rahmenkante des Zen-Frames.
     html:root schlägt das :root-Default aus tokens.css unabhängig
     von der Bundle-Reihenfolge. */
  html:root { --viewport-top: var(--bar-h); }
</style>

<style>
  nav {
    position: sticky;
    top: 0;
    z-index: 70;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    height: var(--bar-h);
    padding: 0 clamp(0.75rem, 2.5vw, 1.25rem);
    background: var(--mantle);
  }
  .brand {
    font-weight: 700;
    font-size: 0.95rem;
    color: var(--text);
    text-decoration: none;
    letter-spacing: -0.02em;
    transition: color var(--dur-fast) var(--ease);
  }
  .brand:hover { color: var(--teal); }

  ul {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    gap: 0.3rem;
    flex-wrap: nowrap;
  }
  ul a {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    color: var(--subtext0);
    text-decoration: none;
    font-size: 0.82rem;
    padding: 0.28rem 0.6rem;
    border-radius: var(--r-chip);
    transition:
      color var(--dur-fast) var(--ease),
      background var(--dur-fast) var(--ease);
  }
  ul a .num {
    font-size: 0.72rem;
    color: var(--overlay2);
    transition: color var(--dur-fast) var(--ease);
  }
  ul a:hover {
    color: var(--text);
    background: var(--surface0);
  }
  ul a:hover .num { color: var(--subtext0); }

  /* Aktiver Workspace: Teal auf Crust */
  ul a[aria-current='true'] {
    background: var(--teal);
    color: var(--crust);
    font-weight: 700;
  }
  ul a[aria-current='true'] .num { color: var(--crust); }

  .clock {
    font-size: 0.82rem;
    color: var(--sky);
    font-variant-numeric: tabular-nums;
  }

  /* 780px statt 760px: bei 761-765px würde „über mich" sonst zweizeilig
     aus der 44px-Bar ragen. Labels bleiben per sr-only-Clip im
     Accessibility-Tree — die Nummer allein ist aria-hidden. */
  @media (max-width: 780px) {
    ul a .label {
      position: absolute;
      width: 1px;
      height: 1px;
      padding: 0;
      margin: -1px;
      overflow: hidden;
      clip-path: inset(50%);
      white-space: nowrap;
    }
    ul a { padding: 0.28rem 0.55rem; }
    ul a .num { font-size: 0.82rem; }
  }
  @media (max-width: 640px) {
    .brand { display: none; }
  }
</style>

<script>
  // Uhr wie in der Bar: HH:MM, minütlich aktualisiert.
  const clock = document.querySelector<HTMLElement>('[data-clock]');
  if (clock) {
    const tick = () => {
      clock.textContent = new Date().toLocaleTimeString('de-DE', {
        hour: '2-digit',
        minute: '2-digit'
      });
    };
    tick();
    setInterval(tick, 15_000);
  }

  // Scrollspy: die zuletzt passierte Section ist der aktive Workspace.
  const navLinks = Array.from(
    document.querySelectorAll<HTMLAnchorElement>('nav a[data-section]')
  );
  const sections = navLinks
    .map((a) => document.getElementById(a.dataset.section ?? ''))
    .filter((el): el is HTMLElement => el !== null);

  let raf = 0;
  const updateActive = () => {
    raf = 0;
    const probe = window.innerHeight * 0.35;
    let current: string | null = null;
    for (const s of sections) {
      if (s.getBoundingClientRect().top <= probe) current = s.id;
    }
    // Letzte Section (kontakt) ist zu kurz, um die Probe-Linie je zu
    // erreichen — am Seitenende gilt sie trotzdem als aktiv.
    if (
      sections.length &&
      window.innerHeight + window.scrollY >= document.documentElement.scrollHeight - 2
    ) {
      current = sections[sections.length - 1].id;
    }
    for (const a of navLinks) {
      if (a.dataset.section === current) a.setAttribute('aria-current', 'true');
      else a.removeAttribute('aria-current');
    }
  };
  window.addEventListener(
    'scroll',
    () => {
      if (!raf) raf = requestAnimationFrame(updateActive);
    },
    { passive: true }
  );
  updateActive();
</script>
