---
import { Image } from 'astro:assets';
import portrait from '../assets/profilepicture.png';
---
<section class="hero" id="top">
  <div class="text">
    <p class="prompt" aria-hidden="true">paul@paul.wtf <span>:~</span></p>
    <h1>
      Paul <em>Reitmayer</em>
    </h1>
    <p class="tagline">
      Elektrotechniker am Erdgasspeicher Bierwang. Software-Engineering als Hobby.
    </p>
    <a class="btn" href="#projects">Projekte ansehen →</a>
  </div>
  <!-- Das eine fokussierte Fenster auf dem Desktop: solider Teal-Border
       wie hyprlands col.active_border im Zen-Modus. -->
  <div class="photo">
    <Image
      src={portrait}
      alt="Foto von Paul Reitmayer"
      width={480}
      height={480}
      loading="eager"
      decoding="async"
    />
  </div>
</section>

<style>
  .hero {
    max-width: 1180px;
    margin: 0 auto;
    padding: clamp(3rem, 8vw, 6rem) clamp(1.25rem, 4vw, 2rem) clamp(2rem, 5vw, 4rem);
    display: grid;
    grid-template-columns: 1.4fr 1fr;
    gap: clamp(1.5rem, 5vw, 3rem);
    align-items: center;
  }
  .prompt {
    margin: 0 0 0.9rem;
    font-size: 0.82rem;
    color: var(--teal);
  }
  .prompt span { color: var(--overlay0); }
  .text h1 {
    font-size: clamp(2.1rem, 5.5vw, 3.4rem);
    font-weight: 800;
  }
  .text h1 em {
    font-style: normal;
    color: var(--teal);
  }
  .tagline {
    color: var(--subtext0);
    font-size: clamp(0.92rem, 1.3vw, 1.02rem);
    line-height: 1.65;
    max-width: 44ch;
    margin: 1rem 0 1.75rem;
  }

  .photo {
    width: 100%;
    aspect-ratio: 1 / 1;
    max-width: 320px;
    justify-self: end;
    overflow: hidden;
    border-radius: var(--r-card);
    box-shadow: 0 0 0 2px var(--teal), var(--card-shadow);
  }
  .photo :global(img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  @media (max-width: 720px) {
    .hero { grid-template-columns: 1fr; }
    .photo { justify-self: center; max-width: 240px; }
  }
</style>
