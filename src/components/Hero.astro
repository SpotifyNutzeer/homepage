---
import { Image } from 'astro:assets';
import portrait from '../assets/profilepicture.png';
---
<section class="hero" id="top">
  <div class="text">
    <h1>
      Paul <em>Reitmayer</em>
    </h1>
    <p class="tagline">
      Elektrotechniker am Erdgasspeicher Bierwang. Software-Engineering als Hobby.
    </p>
    <a class="cta" href="#projects">Projekte ansehen →</a>
  </div>
  <div class="photo glass">
    <Image
      src={portrait}
      alt="Foto von Paul Reitmayer"
      width={480}
      height={480}
      loading="eager"
      decoding="async"
    />
  </div>
</section>

<style>
  .hero {
    max-width: 1180px;
    margin: 0 auto;
    padding: clamp(3rem, 8vw, 6rem) clamp(1rem, 4vw, 2rem) clamp(2rem, 5vw, 4rem);
    display: grid;
    grid-template-columns: 1.4fr 1fr;
    gap: clamp(1.5rem, 5vw, 3rem);
    align-items: center;
  }
  .text h1 {
    font-size: clamp(2.6rem, 6vw, 4.2rem);
  }
  .text h1 em {
    font-style: italic;
    color: var(--accent);
  }
  .tagline {
    color: var(--text-muted);
    font-size: clamp(1rem, 1.4vw, 1.15rem);
    line-height: 1.5;
    max-width: 44ch;
    margin: 1rem 0 1.75rem;
  }
  .cta {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.65rem 1.1rem;
    border-radius: var(--r-pill);
    background: var(--accent);
    color: var(--accent-contrast);
    font-weight: 500;
    text-decoration: none;
    transition: transform var(--dur) var(--ease-spring);
  }
  .cta:hover { transform: translateY(-2px); }

  .photo {
    width: 100%;
    aspect-ratio: 1 / 1;
    max-width: 320px;
    justify-self: end;
    overflow: hidden;
    padding: 0;
  }
  .photo :global(img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  @media (max-width: 720px) {
    .hero { grid-template-columns: 1fr; }
    .photo { justify-self: center; max-width: 240px; }
  }
</style>
