---
import type { ImageMetadata } from 'astro';
import { projects } from '../data/projects';
import ProjectCard from './ProjectCard.astro';

// Match previews by filename: `<project.name>-preview.<ext>` in src/assets/.
// A featured project renders with its preview once the asset exists — no code
// change needed when a new screenshot is added (e.g. via `pnpm capture-previews`).
const previewModules = import.meta.glob<{ default: ImageMetadata }>(
  '../assets/*-preview.{webp,png,jpg,jpeg}',
  { eager: true }
);
const previews: Record<string, ImageMetadata> = {};
for (const [path, mod] of Object.entries(previewModules)) {
  const name = path.split('/').pop()!.replace(/-preview\.\w+$/, '');
  previews[name] = mod.default;
}

const featured = projects.filter((p) => p.featured);
const others = projects.filter((p) => !p.featured);
---
<section id="projects" class="projects section-shell" data-reveal>
  <h2 class="section-title">Projekte</h2>

  {featured.map((p) => <ProjectCard project={p} preview={previews[p.name]} />)}

  <div class="grid">
    {others.map((p) => <ProjectCard project={p} />)}
  </div>
</section>

<style>
  .projects {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }
  .section-title {
    margin-bottom: 0.5rem;
  }
  .grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.25rem;
  }
  @media (max-width: 720px) {
    .grid { grid-template-columns: 1fr; }
  }
</style>
