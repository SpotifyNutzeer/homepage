---
import { tools } from '../data/tools';

// Die ANSI-Palette, die fastfetch unter den Infos ausgibt — Mocha-Terminalfarben.
const palette = [
  '#45475a', '#f38ba8', '#a6e3a1', '#f9e2af',
  '#89b4fa', '#f5c2e7', '#94e2d5', '#bac2de'
];
---
<section id="tools" class="tools section-shell" data-reveal>
  <h2 class="section-title">Tools</h2>
  <!-- Fastfetch-Fenster: user@host, Trennlinie, key/value, Palette. -->
  <div class="window fetch">
    <p class="host">paul@paul.wtf</p>
    <dl>
      {tools.map(({ label, value }) => (
        <div class="row">
          <dt>{label}</dt>
          <dd>{value}</dd>
        </div>
      ))}
    </dl>
    <div class="palette" aria-hidden="true">
      {palette.map((c) => <span style={`background:${c}`} />)}
    </div>
  </div>
</section>

<style>
  .section-title {
    margin-bottom: 1.5rem;
  }
  .fetch {
    max-width: 620px;
    padding: 1.5rem 1.75rem;
  }
  .host {
    margin: 0 0 0.35rem;
    color: var(--teal);
    font-weight: 700;
    font-size: 0.95rem;
  }
  .host::after {
    content: '';
    display: block;
    margin-top: 0.55rem;
    height: 2px;
    background: repeating-linear-gradient(90deg, var(--surface0) 0 10px, transparent 10px 16px);
  }
  dl {
    margin: 0.85rem 0 1.1rem;
    display: grid;
    grid-template-columns: max-content 1fr;
    gap: 0.35rem 1.5rem;
  }
  .row { display: contents; }
  dt {
    color: var(--teal);
    font-size: 0.88rem;
    text-transform: lowercase;
  }
  dd {
    margin: 0;
    color: var(--text);
    font-size: 0.88rem;
  }
  .palette {
    display: flex;
    gap: 0.4rem;
  }
  .palette span {
    width: 1rem;
    height: 1rem;
    border-radius: 4px;
  }
</style>
