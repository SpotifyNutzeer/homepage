---
import { Image } from 'astro:assets';
import { bmw, pax, cats } from '../data/sidefacts';
---
<section id="sidefacts" class="sidefacts section-shell" data-reveal>
  <!-- Der lange Titel würde auf Phones zweizeilig umbrechen und die
       gestrichelte Linie auf 0px kollabieren — Kurzform unter 600px. -->
  <h2 class="section-title">
    <span class="t-long">Wenn ich nicht vor dem Bildschirm sitze</span>
    <span class="t-short">Sidefacts</span>
  </h2>

  <div class="row-large">
    <article class="window card car">
      <div class="visual">
        <Image src={bmw.image} alt="BMW i4 eDrive35" widths={[480, 720, 960]} sizes="(min-width: 720px) 480px, 100vw" />
      </div>
      <div class="text">
        <h3>BMW i4 eDrive35</h3>
        <p>{bmw.text}</p>
      </div>
    </article>

    <article class="window card pax">
      <div class="pax-text">
        <h3>Pax</h3>
        <p class="meta">{pax.species} · {pax.pronouns} · {pax.age}</p>
        <p class="bio">„{pax.description}“</p>
        <div class="taglist">
          <span class="tag-label">mag</span>
          <ul class="tags">
            {pax.likes.map((l) => <li>{l}</li>)}
          </ul>
        </div>
        <div class="taglist">
          <span class="tag-label">mag nicht</span>
          <ul class="tags dislikes">
            {pax.dislikes.map((l) => <li>{l}</li>)}
          </ul>
        </div>
      </div>
      <div class="pax-photo">
        <Image src={pax.image} alt="Fursona Pax (Arctic Fox)" widths={[300, 545]} sizes="(min-width: 720px) 220px, 50vw" />
      </div>
    </article>
  </div>

  <div class="row-cats">
    {cats.map((c) => (
      <article class="window card cat">
        <div class="visual">
          <Image src={c.image} alt={`Katze ${c.name}`} widths={[300, 480, 720]} sizes="(min-width: 720px) 240px, 50vw" />
        </div>
        <div class="cat-body">
          <h4>{c.name}</h4>
          <p>{c.personality}</p>
        </div>
      </article>
    ))}
  </div>
</section>

<style>
  .sidefacts {
    display: flex; flex-direction: column; gap: 1rem;
  }
  .section-title {
    margin-bottom: 0.5rem;
  }
  .t-short { display: none; }
  @media (max-width: 600px) {
    .t-long { display: none; }
    .t-short { display: inline; }
  }

  .row-large {
    display: grid; grid-template-columns: 1fr 1fr; gap: 1rem;
  }
  .row-large > * { min-width: 0; }
  .card { overflow: hidden; padding: 0; }

  .car { display: flex; flex-direction: column; }
  .car .visual {
    width: 100%; aspect-ratio: 16 / 10;
    overflow: hidden;
  }
  .car .visual :global(img) {
    width: 100%; height: 100%;
    object-fit: cover; display: block;
  }
  .car .text { padding: 1.25rem 1.5rem 1.5rem; }
  .car h3 { font-size: 1.1rem; margin-bottom: 0.5rem; }
  .car p { margin: 0; color: var(--subtext0); font-size: 0.88rem; line-height: 1.6; }

  .pax {
    display: grid; grid-template-columns: 1fr 220px;
    gap: 1rem; padding: 1.5rem;
  }
  .pax > * { min-width: 0; }
  .pax-text h3 { font-size: 1.1rem; margin-bottom: 0.25rem; }
  .pax-text .meta {
    color: var(--overlay2); font-size: 0.78rem;
    text-transform: lowercase;
    margin: 0 0 0.85rem;
  }
  .pax-text .bio {
    color: var(--subtext0); font-style: italic;
    font-size: 0.88rem;
    line-height: 1.6; margin: 0 0 1rem;
  }
  .taglist { margin-bottom: 0.6rem; }
  .taglist:last-child { margin-bottom: 0; }
  .tag-label {
    display: block; font-size: 0.78rem;
    text-transform: lowercase;
    color: var(--teal); margin-bottom: 0.3rem;
  }
  .tags {
    list-style: none; margin: 0; padding: 0;
    display: flex; flex-wrap: wrap; gap: 0.3rem;
  }
  /* Opak wie alle Zen-Flächen — Alpha-Tints sind Liquidglass-Vokabular */
  .tags li {
    font-size: 0.74rem; padding: 0.18rem 0.55rem;
    border-radius: var(--r-chip);
    background: var(--surface0);
    color: var(--green);
  }
  .tags.dislikes li {
    color: var(--red);
  }

  .pax-photo {
    border-radius: var(--r-nest); overflow: hidden;
    background: var(--crust);
    align-self: stretch;
  }
  .pax-photo :global(img) {
    width: 100%; height: 100%;
    object-fit: contain; object-position: center;
    display: block;
  }

  .row-cats {
    display: grid; grid-template-columns: repeat(4, 1fr); gap: 1rem;
  }
  .row-cats > * { min-width: 0; }
  .cat .visual {
    width: 100%; aspect-ratio: 4 / 3;
    overflow: hidden;
  }
  .cat .visual :global(img) {
    width: 100%; height: 100%;
    object-fit: cover; display: block;
  }
  .cat-body { padding: 0.85rem 1rem 1rem; }
  .cat-body h4 {
    font-size: 0.95rem; margin: 0 0 0.25rem;
  }
  .cat-body p {
    margin: 0; color: var(--subtext0);
    font-size: 0.8rem; line-height: 1.5;
  }

  @media (max-width: 880px) {
    .row-large { grid-template-columns: 1fr; }
    .row-cats  { grid-template-columns: 1fr 1fr; }
    .pax       { grid-template-columns: 1fr 160px; padding: 1.25rem; }
  }
  @media (max-width: 480px) {
    .pax { grid-template-columns: 1fr; }
    .pax-photo { max-width: 220px; justify-self: center; }
    .row-cats { grid-template-columns: 1fr; }
  }
</style>
