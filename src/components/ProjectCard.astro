---
import type { Project } from '../data/projects';
import type { ImageMetadata } from 'astro';
import { Image } from 'astro:assets';

interface Props {
  project: Project;
  preview?: ImageMetadata;
}

const { project, preview } = Astro.props;
const isLive = !!project.liveUrl;
---
<a class={`pcard window window--focusable ${project.featured ? 'featured' : ''}`} href={project.liveUrl ?? project.repoUrl} target="_blank" rel="noopener noreferrer">
  {preview && (
    <div class="visual">
      <Image
        src={preview}
        alt={`Vorschau von ${project.name}`}
        widths={[640, 960, 1280]}
        sizes="(min-width: 1024px) 1024px, 100vw"
        loading={project.featured ? 'eager' : 'lazy'}
        decoding="async"
      />
    </div>
  )}
  <div class="head">
    <h3>{project.name}</h3>
    {isLive && (
      <span class="live">live · {project.liveUrl?.replace(/^https?:\/\//, '')}</span>
    )}
  </div>
  <p class="desc">{project.description}</p>
  <ul class="stack">
    {project.stack.map((s) => <li>{s}</li>)}
  </ul>
  <div class="links">
    <span class="repo">{project.repoUrl.replace('https://', '')}</span>
  </div>
</a>

<style>
  .pcard {
    display: flex;
    flex-direction: column;
    gap: 0.85rem;
    padding: 1.5rem;
    text-decoration: none;
    color: inherit;
  }

  .pcard.featured { padding: 2rem; gap: 1.1rem; }

  .visual {
    border-radius: var(--r-nest);
    overflow: hidden;
    aspect-ratio: 16 / 9;
    background: var(--crust);
  }
  .visual :global(img) {
    width: 100%; height: 100%; object-fit: cover; display: block;
  }

  .head {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    justify-content: space-between;
    gap: 0.4rem 1rem;
  }
  .head h3 {
    font-size: 1.15rem;
  }
  .pcard.featured .head h3 { font-size: 1.6rem; }

  /* Opak wie alle Zen-Flächen — Alpha-Tints sind Liquidglass-Vokabular */
  .live {
    font-size: 0.72rem;
    padding: 0.2rem 0.55rem;
    border-radius: var(--r-chip);
    background: var(--surface0);
    color: var(--green);
    white-space: nowrap;
  }

  .desc {
    color: var(--subtext0);
    font-size: 0.88rem;
    line-height: 1.6;
    margin: 0;
  }

  .stack {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
    margin-top: auto;
  }
  .stack li {
    font-size: 0.72rem;
    padding: 0.2rem 0.55rem;
    border-radius: var(--r-chip);
    background: var(--surface0);
    color: var(--subtext1);
  }

  .links {
    margin-top: 0.25rem;
    color: var(--overlay2);
    font-size: 0.76rem;
    overflow-wrap: anywhere;
  }
</style>
