---
import Layout from '../layouts/Layout.astro';
---
<Layout title="404 — paul.wtf" description="Diese Seite existiert nicht.">
  <!-- Rot ist für Kritisches reserviert — das hier ist der eine Fall. -->
  <main>
    <div class="window box">
      <h1><em>404</em></h1>
      <p>Hier ist nichts. Vermutlich ein Tippfehler in der URL.</p>
      <a class="btn" href="/">Zur Startseite →</a>
    </div>
  </main>

  <style>
    main {
      min-height: 100vh;
      display: grid;
      place-items: center;
      padding: 2rem;
    }
    .box {
      padding: clamp(2rem, 6vw, 3.5rem);
      text-align: center;
      max-width: 480px;
    }
    h1 {
      font-size: clamp(3rem, 8vw, 5rem);
      font-weight: 800;
    }
    h1 em {
      font-style: normal;
      color: var(--red);
    }
    p {
      color: var(--subtext0);
      font-size: 0.92rem;
      margin: 1rem 0 2rem;
    }
  </style>
</Layout>
